{
  "uid": "lily-graph-performance",
  "title": "Lily — Agent Graph Performance",
  "tags": ["lily"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Full turn latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(lily_chat_turn_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(lily_chat_turn_seconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Per-node latency p95 (by node)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, node) (rate(lily_graph_node_seconds_bucket[5m])))", "legendFormat": "{{node}}" }
      ]
    }
  ]
}
